# ==================================
# IS WEBSITE DOWN - Environment Variables
# ==================================
# Copy this file to .env.local and fill in your values

# ---- Database ----
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/iswebsitedown?schema=public"

# ---- Auth (NextAuth v5) ----
AUTH_SECRET="your-super-secret-key-generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# ---- OAuth Providers (optional) ----
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# ---- Redis ----
REDIS_URL="redis://localhost:6379"

# ---- Email (Resend) ----
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="onboarding@resend.dev"

# ---- App ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="iswebsitedownforeveryone.com"

# ---- Cron / Worker ----
# Set to "true" to enable the background monitor worker
ENABLE_WORKER="true"
